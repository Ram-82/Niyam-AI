# ============================================================
# Niyam AI - Environment Configuration
# ============================================================

# Environment: "development" (default) or "production"
# development = allows MockDB fallback, relaxed validation
# production  = requires real DB, enforces all secrets
ENVIRONMENT=development

# ---- Supabase (PostgreSQL) ----
# Required in production. Optional in development (MockDB used instead).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ---- JWT ----
# Required in production. In dev, falls back to insecure default.
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,https://niyam-ai-zncb.vercel.app

# ---- OCR (future) ----
TESSERACT_PATH=/usr/bin/tesseract
